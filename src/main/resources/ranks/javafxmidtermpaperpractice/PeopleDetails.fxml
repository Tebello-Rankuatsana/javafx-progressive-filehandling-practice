<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ranks.javafxmidtermpaperpractice.PeopleDetails">
   <children>
      <Label layoutX="74.0" layoutY="63.0" prefHeight="34.0" prefWidth="125.0" text="Name" />
      <Label layoutX="74.0" layoutY="127.0" prefHeight="34.0" prefWidth="125.0" text="Surname" />
      <TextField fx:id="txtName" layoutX="238.0" layoutY="60.0" prefHeight="34.0" prefWidth="298.0" />
      <TextField fx:id="txtSurname" layoutX="238.0" layoutY="127.0" prefHeight="34.0" prefWidth="298.0" />
      <RadioButton fx:id="rdFemale" layoutX="137.0" layoutY="199.0" mnemonicParsing="false" prefHeight="18.0" prefWidth="37.0" text="F">
         <toggleGroup>
            <ToggleGroup fx:id="gender" />
         </toggleGroup>
      </RadioButton>
      <RadioButton fx:id="rdMale" layoutX="181.0" layoutY="199.0" mnemonicParsing="false" prefHeight="18.0" prefWidth="37.0" text="M" toggleGroup="$gender" />
      <Label layoutX="74.0" layoutY="191.0" prefHeight="34.0" prefWidth="49.0" text="Gender" />
      <Button fx:id="btnSave" layoutX="65.0" layoutY="343.0" mnemonicParsing="false" onAction="#handleSave" text="Save" />
      <Button fx:id="btnLoad" layoutX="139.0" layoutY="343.0" mnemonicParsing="false" onAction="#handleLoad" text="Load" />
      <TextArea fx:id="txtDisplay" layoutX="268.0" layoutY="182.0" prefHeight="186.0" prefWidth="268.0" />
   </children>
</AnchorPane>
