<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="367.0" prefWidth="613.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ranks.javafxmidtermpaperpractice.TemperatureConverter">
   <children>
      <Label layoutX="165.0" layoutY="95.0" prefHeight="18.0" prefWidth="98.0" text="Temperature" />
      <TextField fx:id="txtTemp" layoutX="287.0" layoutY="91.0" prefHeight="26.0" prefWidth="97.0" promptText="Temp" />
      <TextField layoutX="429.0" layoutY="90.0" prefHeight="26.0" prefWidth="97.0" promptText="Result" />
      <RadioButton fx:id="radioCentigrade" layoutX="165.0" layoutY="148.0" mnemonicParsing="false" prefHeight="18.0" prefWidth="90.0" text="Centigrade">
         <toggleGroup>
            <ToggleGroup fx:id="temp" />
         </toggleGroup>
      </RadioButton>
      <RadioButton fx:id="radioFarenheit" layoutX="346.0" layoutY="148.0" mnemonicParsing="false" prefHeight="18.0" prefWidth="90.0" text="Farenheit" toggleGroup="$temp" />
      <Button fx:id="btnClear" layoutX="165.0" layoutY="211.0" mnemonicParsing="false" text="Clear" />
      <Button fx:id="btnConvert" layoutX="360.0" layoutY="212.0" mnemonicParsing="false" onAction="#calcTemp" text="Convert" />
      <Button fx:id="btnExit" layoutX="476.0" layoutY="294.0" mnemonicParsing="false" prefHeight="26.0" prefWidth="51.0" text="Exit" />
      <Separator layoutX="259.0" layoutY="62.0" prefHeight="8.0" prefWidth="291.0" />
      <Separator layoutX="125.0" layoutY="67.0" orientation="VERTICAL" prefHeight="214.0" prefWidth="3.0" />
      <Separator layoutX="548.0" layoutY="64.0" orientation="VERTICAL" prefHeight="217.0" prefWidth="2.0" />
      <Separator layoutX="126.0" layoutY="277.0" prefHeight="8.0" prefWidth="423.0" />
      <Label layoutX="144.0" layoutY="56.0" text="Convert Temperatures" />
      <Separator layoutX="127.0" layoutY="63.0" prefHeight="8.0" prefWidth="18.0" />
   </children>
</AnchorPane>
